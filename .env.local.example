# App (set to your public URL for iPhone/Mac install — e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true
ENABLE_PWA_DEV=true

# AI
OPENAI_API_KEY=

# eBay (price search - client credentials)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_OAUTH_REDIRECT_URI=http://localhost:3000/api/ebay/oauth/callback

# eBay (in-app posting - seller OAuth tokens as JSON fallback)
EBAY_SELLER_TOKENS_JSON=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_DEFAULT_CATEGORY_ID=9355

# Google Shopping via SerpAPI
SERPAPI_KEY=

# Supabase (optional - uses local file storage when unset)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=